{
  "pack_id": "windows-base",
  "version": "2026.06.29",
  "rules": [
    {"rule_id":"CFG-FW-001","object_types":["windows_firewall"],"profiles":["workstation","server"],"evaluator":"bool_true","field":"Enabled","expected":true,"title":"Windows Firewall profile is enabled","severity":"high","remediation":"Enable the profile through approved policy.","references":[]},
    {"rule_id":"CFG-UAC-001","object_types":["uac_setting"],"profiles":["workstation","server"],"evaluator":"equals","field":"EnableLUA","expected":"1","title":"User Account Control is enabled","severity":"high","remediation":"Enable UAC through approved policy.","references":[]},
    {"rule_id":"CFG-DEF-001","object_types":["defender_status"],"profiles":["workstation"],"evaluator":"bool_true","field":"RealTimeProtectionEnabled","expected":true,"title":"Defender real-time protection is enabled","severity":"high","remediation":"Confirm another approved antivirus or restore protection.","references":[]},
    {"rule_id":"CFG-SMB-001","object_types":["smb_configuration"],"profiles":["workstation","server"],"evaluator":"bool_false","field":"EnableSMB1Protocol","expected":false,"title":"SMBv1 is disabled","severity":"critical","remediation":"Remove legacy dependencies and disable SMBv1.","references":[]},
    {"rule_id":"CFG-RDP-001","object_types":["remote_desktop"],"profiles":["workstation","server"],"evaluator":"rdp_nla","field":"UserAuthentication","expected":"1 when RDP is enabled","title":"RDP requires NLA","severity":"high","remediation":"Require NLA when RDP is enabled.","references":[]},
    {"rule_id":"CFG-PASS-001","object_types":["password_policy"],"profiles":["workstation","server"],"evaluator":"numeric_min","field":"MinimumPasswordLength","expected":12,"title":"Minimum password length is at least 12","severity":"medium","remediation":"Set the approved minimum password length.","references":[]},
    {"rule_id":"CFG-LOCK-001","object_types":["password_policy"],"profiles":["workstation","server"],"evaluator":"numeric_range","field":"LockoutThreshold","expected":[1,10],"title":"Account lockout threshold is configured","severity":"medium","remediation":"Configure a nonzero lockout threshold.","references":[]},
    {"rule_id":"CFG-GUEST-001","object_types":["user"],"profiles":["workstation","server"],"evaluator":"guest_disabled","field":"Disabled","expected":true,"title":"Built-in Guest account is disabled","severity":"high","remediation":"Disable the built-in Guest account.","references":[]},
    {"rule_id":"CFG-PASS-AGE-001","object_types":["user"],"profiles":["workstation","server"],"evaluator":"password_age_threshold","field":"PasswordAgeDays","expected":{"warning_days":60,"critical_days":90},"title":"User password age is within policy","severity":"warning","remediation":"Change passwords older than 60 days; treat accounts older than 90 days as critical until remediated.","references":[]},
    {"rule_id":"CFG-AUDIT-001","object_types":["audit_policy"],"profiles":["workstation","server"],"evaluator":"audit_enabled","field":"Setting","expected":"auditing enabled","title":"Security auditing is enabled","severity":"medium","remediation":"Enable the required audit subcategory.","references":[]},
    {"rule_id":"EXP-AUTORUN-001","object_types":["startup_program","active_setup"],"profiles":["workstation","server"],"evaluator":"safe_executable_path","field":"Command","expected":"protected absolute path","title":"Autostart path is protected","severity":"high","remediation":"Review and remove unsafe autostart entries.","references":[]},
    {"rule_id":"EXP-TASK-001","object_types":["scheduled_task"],"profiles":["workstation","server"],"evaluator":"safe_executable_path","field":"Execute","expected":"protected absolute path","title":"Scheduled task path is protected","severity":"high","remediation":"Review and replace unsafe task actions.","references":[]},
    {"rule_id":"EXP-SVC-001","object_types":["service"],"profiles":["workstation","server"],"evaluator":"quoted_service_path","field":"PathName","expected":"quoted executable path","title":"Service path is safely quoted","severity":"high","remediation":"Quote the service executable path.","references":[]},
    {"rule_id":"EXP-DRV-001","object_types":["driver"],"profiles":["workstation","server"],"evaluator":"bool_true","field":"IsSigned","expected":true,"title":"Driver is digitally signed","severity":"high","remediation":"Replace with a signed supported driver.","references":[]},
    {"rule_id":"EXP-PORT-001","object_types":["open_port"],"profiles":["workstation","server"],"evaluator":"sensitive_port_exposure","field":"Local Port","expected":"restricted binding","title":"Sensitive port exposure is restricted","severity":"medium","remediation":"Restrict the service with approved firewall policy.","references":[]},
    {"rule_id":"EXP-ICS-001","object_types":["open_port"],"profiles":["workstation","server"],"evaluator":"industrial_protocol_exposure","field":"Local Port","expected":"industrial protocols are not exposed on all interfaces","title":"Industrial protocol exposure is restricted","severity":"high","remediation":"Restrict Modbus, S7, DNP3, IEC-104, EtherNet/IP, BACnet and similar industrial services to approved management networks or disable unused listeners.","references":[]},
    {"rule_id":"ENV-PATH-001","object_types":["environment_variable"],"profiles":["workstation","server"],"evaluator":"safe_path_entries","field":"Value","expected":"protected absolute entries","title":"PATH avoids unsafe entries","severity":"high","remediation":"Remove relative or user-writable PATH entries.","references":[]}
  ]
}
